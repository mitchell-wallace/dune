version: 1
mode: balanced
enforce: true
api_allowlist:
{{- range .APIAllowlist }}
  - {{ . | printf "%q" }}
{{- end }}
fetch_proxy:
  monitoring:
    max_requests_per_minute: {{ .MaxRequestsPerMinute }}
    blocklist:
{{- range .Blocklist }}
      - {{ . | printf "%q" }}
{{- end }}
forward_proxy:
  enabled: true
dlp:
  include_defaults: true
response_scanning:
  enabled: true
  action: warn
logging:
  format: json
  output: stdout

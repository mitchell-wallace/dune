{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Australia/Melbourne}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
      "SAND_BUILD_MODE": "${localEnv:SAND_BUILD_MODE:std}",
      "SAND_BUILD_ADDONS": "${localEnv:SAND_BUILD_ADDONS:}",
      "SAND_PYTHON_VERSION": "${localEnv:SAND_PYTHON_VERSION:}",
      "SAND_UV_VERSION": "${localEnv:SAND_UV_VERSION:}",
      "SAND_GO_VERSION": "${localEnv:SAND_GO_VERSION:}",
      "SAND_RUST_VERSION": "${localEnv:SAND_RUST_VERSION:}",
      "SAND_DOTNET_VERSION": "${localEnv:SAND_DOTNET_VERSION:}",
      "SAND_JAVA_VERSION": "${localEnv:SAND_JAVA_VERSION:}",
      "SAND_MAVEN_VERSION": "${localEnv:SAND_MAVEN_VERSION:}",
      "SAND_GRADLE_VERSION": "${localEnv:SAND_GRADLE_VERSION:}",
      "SAND_BUN_VERSION": "${localEnv:SAND_BUN_VERSION:}",
      "SAND_DENO_VERSION": "${localEnv:SAND_DENO_VERSION:}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "biomejs.biome"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=agent-persist-${localEnv:SAND_PROFILE:0},target=/persist/agent,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "TZ": "${localEnv:TZ:Australia/Melbourne}",
    "LANG": "${localEnv:LANG:en_AU.UTF-8}",
    "LANGUAGE": "${localEnv:LANGUAGE:en_AU:en}",
    "SAND_PROFILE": "${localEnv:SAND_PROFILE:0}",
    "SAND_SECURITY_MODE": "${localEnv:SAND_SECURITY_MODE:std}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "/usr/local/bin/sand-poststart.sh",
  "waitFor": "postStartCommand"
}
